<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="OledPaintPro.MainWindow"
        Title="OLED Paint Pro"
        Width="1530" Height="1168"
        MinWidth="672" MinHeight="378"
        Background="#141414"
        FontFamily="Segoe UI Emoji, Segoe UI"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        MouseWheel="Window_MouseWheel"
        PreviewMouseDown="Window_PreviewMiddleDown"
        PreviewMouseMove="Window_PreviewMiddleMove"
        PreviewMouseUp="Window_PreviewMiddleUp">

    <Window.Resources>

        <!-- ══ Rozmiary ikon narzędzi ══════════════════════════════════════ -->
        <!-- Podstawowe -->
        <sys:Double x:Key="IconSizePencil">17</sys:Double>
        <sys:Double x:Key="IconSizeEraser">17</sys:Double>
        <sys:Double x:Key="IconSizeFill">17</sys:Double>
        <!-- Kształty -->
        <sys:Double x:Key="IconSizeLine">18</sys:Double>
        <sys:Double x:Key="IconSizeRect">15</sys:Double>
        <sys:Double x:Key="IconSizeFilledRect">15</sys:Double>
        <sys:Double x:Key="IconSizeEllipse">18</sys:Double>
        <sys:Double x:Key="IconSizeFilledEllipse">18</sys:Double>
        <!-- Emoji -->
        <sys:Double x:Key="IconSizeEye">15</sys:Double>
        <sys:Double x:Key="IconSizeSmile">18</sys:Double>
        <sys:Double x:Key="IconSizeFrown">18</sys:Double>
        <sys:Double x:Key="IconSizeScatter">16</sys:Double>


        <!-- ── Symetria ToggleButton style ── -->
        <Style x:Key="SymToggleBtn" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width"  Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Bd"
                                Background="#232323"
                                BorderBrush="#383838"
                                BorderThickness="2"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#2A0A0A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF5544"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF3333" BlurRadius="18"
                                                          ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#2E1A1A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#AA4433"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tool RadioButton style -->
        <Style x:Key="ToolBtn" TargetType="{x:Type RadioButton}">
            <Setter Property="GroupName"      Value="Tools"/>
            <Setter Property="Width"          Value="40"/>
            <Setter Property="Height"         Value="36"/>
            <Setter Property="Margin"         Value="2"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bd"
                                Background="#232323"
                                BorderBrush="#383838"
                                BorderThickness="2"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#D0DCFF"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1A2240"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5588EE"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#4477FF" BlurRadius="18"
                                                          ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#272B38"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6677AA"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3355BB" BlurRadius="12"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── OLED Special Tool style (teal accent) ── -->
        <Style x:Key="OledBtn" TargetType="{x:Type RadioButton}">
            <Setter Property="GroupName"      Value="Tools"/>
            <Setter Property="Width"          Value="40"/>
            <Setter Property="Height"         Value="36"/>
            <Setter Property="Margin"         Value="2"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bd"
                                Background="#181E1E"
                                BorderBrush="#2A3A34"
                                BorderThickness="2"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#A8FFE0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#0D2820"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#28D09A"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#20D090" BlurRadius="18"
                                                          ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#0E2420"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1A9068"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#18AA70" BlurRadius="12"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Header action button ── -->
        <!-- ── HdrBtn i PanelBtn przeniesione do App.xaml (globalne) ── -->

        <!-- ── Dark TextBox ── -->
        <Style x:Key="DarkTB" TargetType="{x:Type TextBox}">
            <Setter Property="Background"   Value="#1A1A1A"/>
            <Setter Property="Foreground"   Value="#C8C8C8"/>
            <Setter Property="CaretBrush"   Value="#5599FF"/>
            <Setter Property="BorderBrush"  Value="#383838"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style x:Key="DarkCombo" TargetType="{x:Type ComboBox}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="Foreground"        Value="#909090"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn"
                                          OverridesDefaultStyle="True"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Bd"
                                                Background="#111111"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="18"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="7,4,0,4"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="▾"
                                                           Foreground="#484848"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#383838"/>
                                                <Setter TargetName="Bd" Property="Background"  Value="#161616"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4A6A"/>
                                                <Setter TargetName="Bd" Property="Background"  Value="#0E0E0E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="7,4,20,4"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="#909090"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropBd"
                                        Background="#0E0E0E"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="0,0,4,4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}">
                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                        <Setter Property="Foreground"  Value="#808080"/>
                        <Setter Property="FontSize"    Value="10"/>
                        <Setter Property="Padding"     Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                    <Border x:Name="ItemBd"
                                            Background="Transparent"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#1A1E2A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#141A30"/>
                                            <Setter Property="Foreground" Value="#6080CC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark CheckBox ── -->
        <Style x:Key="DarkCB" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#909090"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

        <!-- ── section label ── -->
        <Style x:Key="SectLbl" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize"   Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#606060"/>
            <Setter Property="Margin"     Value="4,10,4,2"/>
        </Style>

        <!-- ── Dark ScrollBar ── -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Border Background="#141414">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThBd" Background="#383838"
                                                        CornerRadius="4" Margin="2,2">
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="MouseOver">
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="ThBd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="#5588EE" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="ThBd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="#4477CC" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width"    Value="8"/>
                    <Setter Property="MinWidth" Value="8"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Tab bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="26"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Grid.ColumnSpan="2">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="3,1" Margin="0,0,8,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#6699FF" BlurRadius="18"
                                              ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <TextBlock Text="🖥" FontSize="24" VerticalAlignment="Center" Foreground="#6699FF"/>
                    </Border>
                    <TextBlock Text="OLED Paint Pro" FontSize="16" FontWeight="Bold"
                               Foreground="#6699FF" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HeaderSizeLabel" Text=" · 128×64 px" FontSize="14"
                               Foreground="#555555" VerticalAlignment="Center" Height="17"/>
                </StackPanel>

                <!-- Topbar — Otwórz .h / Wklej kod / Kopiuj / Animacja -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Otwórz .h -->
                    <Button Style="{StaticResource HdrBtn}" Click="OpenFromFile_Click"
                            Margin="0,0,4,0" ToolTip="Otwórz bitmapę z pliku .h (C array)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" FontSize="12" Margin="0,-1,5,0"/>
                            <TextBlock Text="Otwórz .h" Foreground="#88BBFF"/>
                        </StackPanel>
                    </Button>

                    <!-- Wklej kod -->
                    <Button Style="{StaticResource HdrBtn}" Click="PasteCode_Click"
                            Margin="0,0,10,0" ToolTip="Wklej kod C — tablica bitmapy">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="12" Margin="0,-1,5,0"/>
                            <TextBlock Text="Wklej kod" Foreground="#88BBFF"/>
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Background="#333" Margin="0,8,10,8"/>

                    <!-- Kopiuj rysunek -->
                    <Button Style="{StaticResource HdrBtn}" Click="CopyCurrentDrawing_Click"
                            Margin="0,0,10,0" ToolTip="Duplikuj aktywny rysunek (auto-numeracja)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⧉" FontSize="13" Margin="0,-1,5,0" Foreground="#AADDFF"/>
                            <TextBlock Text="Kopiuj" Foreground="#AADDFF"/>
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Background="#333" Margin="0,8,10,8"/>

                    <!-- Nowa animacja -->
                    <Button Style="{StaticResource HdrBtn}" Click="NewAnimation_Click"
                            ToolTip="Nowy edytor animacji (klatka po klatce + eksport ESP32)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬" FontSize="12" Margin="0,-1,5,0"/>
                            <TextBlock Text="Animacja" Foreground="#FFCC00"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource HdrBtn}" Click="NewSprite_Click"
                            ToolTip="Nowy edytor sprite'a (ruch + eksport include ESP32)" Margin="4,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🕹️" FontSize="12" Margin="0,-1,5,0"/>
                            <TextBlock Text="Sprite" Foreground="#FF9900"/>
                        </StackPanel>
                    </Button>

                    <!-- Nowy sprite -->

                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource HdrBtn}" Click="Undo_Click" Margin="0,0,5,0" ToolTip="Ctrl+Z">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↩" Margin="0,0,4,0" Foreground="#6E6E6E"/>
                            <TextBlock Text="Cofnij" Foreground="#6E6E6E"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource HdrBtn}" Click="Redo_Click" Margin="0,0,5,0" ToolTip="Ctrl+Y">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↪" Margin="0,0,4,0" Foreground="#6E6E6E"/>
                            <TextBlock Text="Ponów" Foreground="#6E6E6E"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource HdrBtn}" Click="Clear_Click" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊕" Margin="0,-4,4,0" FontSize="16" Foreground="#6E6E6E"/>
                            <TextBlock Text="Wyczyść" Margin="0,1,0,0" Foreground="#6E6E6E"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource HdrBtn}" Click="Invert_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊘" Margin="0,-4,4,0" FontSize="16" Foreground="#6E6E6E"/>
                            <TextBlock Text="Odwróć" Margin="0,1,0,0" Foreground="#6E6E6E"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ TAB BAR ═══════════════ -->
        <Border Grid.Row="1" x:Name="TabBarBorder" Background="#161616"
                BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <DockPanel Height="30" LastChildFill="False">
                <ScrollViewer DockPanel.Dock="Left" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabBar" Orientation="Horizontal" Height="30"/>
                </ScrollViewer>
                <!-- Przycisk nowej zakładki -->
                <Button x:Name="NewDrawingTabBtn" DockPanel.Dock="Left"
                        Content="＋" FontSize="13" Width="30" Height="24"
                        VerticalAlignment="Center" Margin="2,0,0,0" Cursor="Hand"
                        ToolTip="Nowy rysunek (Ctrl+T)"
                        Click="NewDrawingTab_Click"
                        OverridesDefaultStyle="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1A1A1A" BorderBrush="#383838"
                                    BorderThickness="1" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextElement.Foreground="#606060"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#222244"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#5566AA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#141428"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- ═══════════════ MAIN AREA ═══════════════ -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <!-- Toolbox -->
                <ColumnDefinition Width="*"/>
                <!-- Canvas -->
                <ColumnDefinition Width="Auto"/>
                <!-- Right panel -->
                <!-- Toggle button -->
                <ColumnDefinition x:Name="RightPanelCol" Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT TOOLBOX ─── -->
            <Border Grid.Column="0" Background="#181818"
                    BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,5,-1,-5">
                    <StackPanel Margin="6,6" HorizontalAlignment="Center">

                        <!-- PODSTAWOWE -->
                        <TextBlock Text="PODSTAWOWE" Style="{StaticResource SectLbl}"/>
                        <UniformGrid Columns="2">
                            <RadioButton Style="{StaticResource ToolBtn}" Tag="Pencil"
                                         IsChecked="True" Checked="Tool_Changed"
                                         ToolTip="Ołówek — LPM rysuj, PPM gumka" Height="35">
                                <TextBlock Text="✏" FontSize="{StaticResource IconSizePencil}" Foreground="#6699FF" Height="25">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ToolBtn}" Tag="Eraser"
                                         Checked="Tool_Changed" ToolTip="Gumka — LPM czyść">
                                <TextBlock Text="🧽" FontSize="{StaticResource IconSizeEraser}" Width="24" Height="25" Foreground="#6699FF">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0" CenterX="12" CenterY="12"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton x:Name="FillToolBtn" Style="{StaticResource ToolBtn}" Tag="FloodFill"
                                         Checked="Tool_Changed" ToolTip="Wypełnienie · PPM = szum"
                                         MouseRightButtonUp="FillToolBtn_RightClick">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="🪣  Wypełnienie"       Tag="FloodFill" Click="FillMenu_Click"/>
                                        <MenuItem Header="❄  Szum (losowe piksele)" Tag="Scatter"   Click="FillMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="🪣" FontSize="{StaticResource IconSizeFill}" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ToolBtn}" Tag="Select"
                                         Checked="Tool_Changed"
                                         ToolTip="Zaznaczanie — zaznacz obszar, przenieś, scal (Esc = anuluj)"
                                         Height="35">
                                <TextBlock Text="⬚" FontSize="17" Foreground="#6699FF" Height="25">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ToolBtn}" Tag="Text"
                                         Checked="Tool_Changed"
                                         ToolTip="Tekst — kliknij na kanwę, wpisz tekst, zatwierdź Enter lub klik poza"
                                         Height="35">
                                <TextBlock Text="T" FontSize="17" FontWeight="Bold" Foreground="#6699FF" Height="25">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </UniformGrid>

                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#2A2A2A"/>

                        <!-- KSZTAŁTY -->
                        <TextBlock Text="KSZTAŁTY" Style="{StaticResource SectLbl}"/>
                        <UniformGrid Columns="2">
                            <!-- Linia (kontur + HLine + VLine w PPM) -->
                            <RadioButton x:Name="LineToolBtn"
                                         Style="{StaticResource ToolBtn}" Tag="Line"
                                         Checked="Tool_Changed"
                                         MouseRightButtonUp="LineToolBtn_RightClick"
                                         ToolTip="Linia prosta · PPM = więcej opcji">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="╱  Linia prosta"        Tag="Line"  Click="LineMenu_Click"/>
                                        <MenuItem Header="—  Linia pozioma"       Tag="HLine" Click="LineMenu_Click"/>
                                        <MenuItem Header="│  Linia pionowa"       Tag="VLine" Click="LineMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="╱" FontSize="{StaticResource IconSizeLine}" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <!-- Prostokąt (kontur + wypełniony w PPM) -->
                            <RadioButton x:Name="RectToolBtn"
                                         Style="{StaticResource ToolBtn}" Tag="Rect"
                                         Checked="Tool_Changed"
                                         MouseRightButtonUp="RectToolBtn_RightClick"
                                         ToolTip="Prostokąt (kontur) · PPM = więcej opcji">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="▭  Prostokąt — kontur"     Tag="Rect"       Click="RectMenu_Click"/>
                                        <MenuItem Header="▬  Prostokąt — wypełniony" Tag="FilledRect" Click="RectMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="▭" FontSize="{StaticResource IconSizeRect}" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <!-- Elipsa (kontur + wypełniona w PPM) -->
                            <RadioButton x:Name="EllipseToolBtn"
                                         Style="{StaticResource ToolBtn}" Tag="Ellipse"
                                         Checked="Tool_Changed"
                                         MouseRightButtonUp="EllipseToolBtn_RightClick"
                                         ToolTip="Elipsa (kontur) · PPM = więcej opcji">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="○  Elipsa — kontur"      Tag="Ellipse"       Click="EllipseMenu_Click"/>
                                        <MenuItem Header="●  Elipsa — wypełniona"  Tag="FilledEllipse" Click="EllipseMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="○" FontSize="{StaticResource IconSizeEllipse}" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton x:Name="TriangleToolBtn" Style="{StaticResource ToolBtn}" Tag="Triangle"
                                         Checked="Tool_Changed" ToolTip="Trójkąt · PPM = wypełniony"
                                         MouseRightButtonDown="TriangleToolBtn_RightClick">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="△  Trójkąt (kontur)"   Tag="Triangle"       Click="TriangleMenu_Click"/>
                                        <MenuItem Header="▲  Trójkąt (wypełniony)" Tag="FilledTriangle" Click="TriangleMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="△" FontSize="15" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton x:Name="CrossToolBtn" Style="{StaticResource ToolBtn}" Tag="Cross"
                                         Checked="Tool_Changed" ToolTip="Krzyż / plus · PPM = więcej opcji"
                                         MouseRightButtonUp="CrossToolBtn_RightClick">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="✚  Krzyż / plus" Tag="Cross" Click="CrossMenu_Click"/>
                                        <MenuItem Header="✦  Gwiazdka"     Tag="Star"  Click="CrossMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="✚" FontSize="14" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton x:Name="ArcToolBtn" Style="{StaticResource ToolBtn}" Tag="ArcDown"
                                         Checked="Tool_Changed" ToolTip="Łuk dolny · PPM = więcej opcji"
                                         MouseRightButtonUp="ArcToolBtn_RightClick">
                                <RadioButton.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="⌣  Łuk dolny"          Tag="ArcDown" Click="ArcMenu_Click"/>
                                        <MenuItem Header="⌢  Łuk górny"          Tag="ArcUp"   Click="ArcMenu_Click"/>
                                        <MenuItem Header="∪  Język / usta otwarte" Tag="Tongue"  Click="ArcMenu_Click"/>
                                    </ContextMenu>
                                </RadioButton.ContextMenu>
                                <TextBlock Text="⌣" FontSize="16" Foreground="#6699FF" TextAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6699FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </UniformGrid>

                        <!-- OŚ SYMETRII przeniesiona — placeholder pusty, właściwa sekcja pod ODBICIAMI -->


                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#1E2E26"/>

                        <!-- OCZY -->
                        <TextBlock Text="OCZY" Style="{StaticResource SectLbl}" Foreground="#28A078"/>
                        <Grid Height="43" Width="64">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <!-- ▾ najpierw w XAML → pod spodem warstwy -->
                            <Button x:Name="EyePickerBtn"
                                        Content="▽" FontSize="9" Cursor="Hand"
                                        ToolTip="Biblioteka oczu"
                                        Click="EyePickerBtn_Click"
                                        OverridesDefaultStyle="True" Margin="41,7,6,7" Grid.ColumnSpan="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#181E1E" BorderBrush="#2A3A34"
                                                    BorderThickness="1" CornerRadius="0,5,5,0">
                                            <TextBlock Text="▽" Foreground="#A8FFE0" FontSize="9"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0E2420"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1A9068"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- RadioButton później → na wierzchu -->
                            <RadioButton Grid.Column="0" Style="{StaticResource OledBtn}" Tag="EyeStamp"
                                         Checked="Tool_Changed" ToolTip="Stempel oka z biblioteki">
                                <TextBlock Text="👁" FontSize="{StaticResource IconSizeEye}" Foreground="#2EE89A" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#20D090" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#1E2E26"/>

                        <!-- USTA — biblioteka -->
                        <TextBlock Text="USTA" Style="{StaticResource SectLbl}" Foreground="#FF9944"/>
                        <Grid Height="43" Width="64">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="MouthPickerBtn"
                                    Content="▽" FontSize="9" Cursor="Hand"
                                    ToolTip="Biblioteka ust"
                                    Click="MouthPickerBtn_Click"
                                    OverridesDefaultStyle="True" Margin="41,7,6,7" Grid.ColumnSpan="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#1E1808" BorderBrush="#3A2A10"
                                                BorderThickness="1" CornerRadius="0,5,5,0">
                                            <TextBlock Text="▽" Foreground="#FFD080" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#241000"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF8844"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <RadioButton Grid.Column="0" Style="{StaticResource OledBtn}" Tag="MouthStamp"
                                         Checked="Tool_Changed" ToolTip="Stempel ust z biblioteki">
                                <TextBlock Text="😊" FontSize="15" Foreground="#FF9944" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF6600" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#1E2E26"/>

                        <!-- INNE — biblioteka -->
                        <TextBlock Text="INNE" Style="{StaticResource SectLbl}" Foreground="#AA88FF"/>
                        <Grid Height="43" Width="64">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="OtherPickerBtn"
                                    Content="▽" FontSize="9" Cursor="Hand"
                                    ToolTip="Biblioteka innych ikon"
                                    Click="OtherPickerBtn_Click"
                                    OverridesDefaultStyle="True" Margin="41,7,6,7" Grid.ColumnSpan="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#180E24" BorderBrush="#3A1A50"
                                                BorderThickness="1" CornerRadius="0,5,5,0">
                                            <TextBlock Text="▽" Foreground="#CC88FF" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#200C30"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#AA44FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <RadioButton Grid.Column="0" Style="{StaticResource OledBtn}" Tag="OtherStamp"
                                         Checked="Tool_Changed" ToolTip="Stempel z biblioteki Inne">
                                <TextBlock Text="★" FontSize="15" Foreground="#CC88FF" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#8800FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#1E2E26"/>

                        <!-- BITMAPY — biblioteka predefiniowanych -->
                        <TextBlock Text="BITMAPS" Style="{StaticResource SectLbl}" Foreground="#2299CC"/>
                        <Grid Height="43" Width="64">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BitmapPickerBtn"
                                    Content="▽" FontSize="9" Cursor="Hand"
                                    ToolTip="Biblioteka bitmap (predefiniowane + własne)"
                                    Click="BitmapPickerBtn_Click"
                                    OverridesDefaultStyle="True" Margin="41,7,6,7" Grid.ColumnSpan="2">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#081820" BorderBrush="#183A50"
                                                BorderThickness="1" CornerRadius="0,5,5,0">
                                            <TextBlock Text="▽" Foreground="#55CCFF" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0C2030"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2299CC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <RadioButton Grid.Column="0" Style="{StaticResource OledBtn}" Tag="BitmapStamp"
                                         Checked="Tool_Changed" ToolTip="Stempel bitmap — wybierz z biblioteki">
                                <TextBlock Text="🖼" FontSize="14" Foreground="#55CCFF" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#0088FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </RadioButton>
                        </Grid>



                        <!-- ODBICIA — jednorazowe przyciski -->
                        <TextBlock Text="ODBICIA" Style="{StaticResource SectLbl}" Foreground="#FFAA33" Margin="0,6,0,0"/>
                        <UniformGrid Columns="2">
                            <Button Width="40" Height="36" Margin="2" Cursor="Hand"
                                    ToolTip="Odbij poziomo — lewo ↔ prawo"
                                    Click="FlipH_Click" OverridesDefaultStyle="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#232320" BorderBrush="#554422"
                                                BorderThickness="2" CornerRadius="7">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#332810"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFAA33"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#443311"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="↔" FontSize="15" Foreground="#FFAA33" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FFAA33" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Button>
                            <Button Width="40" Height="36" Margin="2" Cursor="Hand"
                                    ToolTip="Odbij pionowo — góra ↔ dół"
                                    Click="FlipV_Click" OverridesDefaultStyle="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#232320" BorderBrush="#554422"
                                                BorderThickness="2" CornerRadius="7">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#332810"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFAA33"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#443311"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="↕" FontSize="15" Foreground="#FFAA33" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FFAA33" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Button>
                        </UniformGrid>

                        <!-- OŚ SYMETRII — pod odbiciami -->
                        <TextBlock Text="OŚ SYMETRII" Style="{StaticResource SectLbl}" Foreground="#FF6655" Margin="0,6,0,0"/>
                        <UniformGrid Columns="2">
                            <ToggleButton x:Name="SymVToggle"
                                          Style="{StaticResource SymToggleBtn}"
                                          ToolTip="Oś symetrii pionowa — działa z każdym narzędziem"
                                          Checked="SymV_Checked" Unchecked="SymV_Unchecked">
                                <TextBlock Text="⇹" FontSize="14" Foreground="#FF6655" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF4444" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </ToggleButton>
                            <ToggleButton x:Name="SymHToggle"
                                          Style="{StaticResource SymToggleBtn}"
                                          ToolTip="Oś symetrii pozioma — działa z każdym narzędziem"
                                          Checked="SymH_Checked" Unchecked="SymH_Unchecked">
                                <TextBlock Text="⇵" FontSize="14" Foreground="#FF6655" Height="22">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF4444" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </ToggleButton>
                        </UniformGrid>

                        <!-- Divider -->
                        <Rectangle Height="1" Margin="4,10,4,0" Fill="#2A2A2A"/>

                        <!-- ZOOM -->
                        <TextBlock Text="ZOOM" Style="{StaticResource SectLbl}"/>
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Width="84">
                                <Button Content="−" Style="{StaticResource HdrBtn}"
                                        Width="28" Height="26" Click="ZoomOut_Click"
                                        Padding="0"/>
                                <TextBlock x:Name="ZoomLabel" Text="6×"
                                           Width="28" TextAlignment="Center"
                                           Foreground="#8899CC" FontSize="13" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <Button Content="+" Style="{StaticResource HdrBtn}"
                                        Width="28" Height="26" Click="ZoomIn_Click"
                                        Padding="0"/>
                            </StackPanel>
                            <TextBlock x:Name="CanvasSizeLabel" Text="768×384 px"
                                       FontSize="8" Foreground="#505050"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── CANVAS AREA (legacy — ukryty) ─── -->
            <Border x:Name="CanvasScrollBorder" Grid.Column="1" Background="#1C1C1C">
                <ScrollViewer x:Name="CanvasScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#1C1C1C" Margin="0,0,-2,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="30">
                        <!-- OLED bezel / screen frame -->
                        <Border BorderBrush="#0B0E45" BorderThickness="6"
                                CornerRadius="10" Background="#000000">
                            <Border.Effect>
                                <DropShadowEffect Color="#101363" BlurRadius="20"
                                                  ShadowDepth="0" Opacity="0.45"/>
                            </Border.Effect>
                            <Border BorderBrush="#000000" BorderThickness="2"
                                    CornerRadius="6">
                                <Image x:Name="CanvasImage"
                                       Stretch="None"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Cursor="Cross"/>
                            </Border>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── EYE EDITOR TAB CONTENT ─── -->
            <ContentControl x:Name="TabContent"
                            Grid.Column="1"
                            Visibility="Collapsed"/>

            <!-- EMPTY STATE — brak kart -->
            <Border x:Name="EmptyStatePanel" Grid.Column="1"
        Background="#161616" Visibility="Collapsed"
        Padding="16" ClipToBounds="False">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="320">
                    <TextBlock Text="🖥" FontSize="64"
                   FontFamily="Segoe UI Emoji"
                   HorizontalAlignment="Center" Margin="0,0,0,16"
                   LineStackingStrategy="BlockLineHeight" LineHeight="72">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#6699FF" BlurRadius="30"
                                  ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="OLED Paint Pro"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#3A4A70"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"/>

                    <TextBlock Text="Brak otwartych rysunków"
                   FontSize="12" Foreground="#404040"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,28"/>

                    <Button Content="Nowy rysunek?"
                Style="{StaticResource PanelBtn}"
                FontSize="14" Padding="24,5"
                HorizontalAlignment="Center"
                Click="NewDrawingTab_Click"
                Foreground="#88BBFF" BorderBrush="#3355AA"
                Background="#0D1428">
                        <Button.Effect>
                            <DropShadowEffect Color="#4477FF" BlurRadius="18"
                                  ShadowDepth="0" Opacity="0.35"/>
                        </Button.Effect>
                    </Button>

                    <TextBlock Text="Ctrl+T — nowy rysunek  ·  Kółko myszy = zoom"
                   FontSize="9" Foreground="#505050"
                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- ─── TOGGLE BUTTON ─── -->
            <Button x:Name="ToggleRightPanelBtn"
                    Grid.Column="2"
                    Content="▶"
                    Width="18"
                    Cursor="Hand"
                    ToolTip="Zwiń / Rozwiń panel ustawień"
                    Click="ToggleRightPanel_Click"
                    OverridesDefaultStyle="True">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="#1E1E1E"
                                BorderBrush="#383838"
                                BorderThickness="1,0,1,0">
                            <TextBlock x:Name="Arrow"
                                       Text="▶"
                                       Foreground="#6070A0"
                                       FontSize="9"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"    Property="Background"  Value="#252B3A"/>
                                <Setter TargetName="Bd"    Property="BorderBrush" Value="#5566AA"/>
                                <Setter TargetName="Arrow" Property="Foreground"  Value="#99BBFF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3355BB" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd"    Property="Background"  Value="#1A2040"/>
                                <Setter TargetName="Arrow" Property="Foreground"  Value="#C0D8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ─── RIGHT PANEL ─── -->
            <Border x:Name="RightPanelBorder" Grid.Column="3" Background="#181818"
                    BorderBrush="#2A2A2A" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Settings -->
                        <RowDefinition Height="*"/>
                        <!-- Code output -->
                        <RowDefinition Height="Auto"/>
                        <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <!-- Settings -->
                    <StackPanel Grid.Row="0" Margin="12,10,12,8">

                        <TextBlock Text="USTAWIENIA" Style="{StaticResource SectLbl}"
                                   Margin="0,0,0,6"/>

                        <!-- Elementy widoczne tylko dla kart rysowania (nie animacji) -->
                        <StackPanel x:Name="DrawingSettingsPanel">

                            <TextBlock Text="Ekran OLED:"
                                   Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="OledDisplayCombo"
                                  Style="{StaticResource DarkCombo}"
                                  Margin="0,0,0,8"
                                  SelectionChanged="OledDisplay_Changed">
                                <ComboBoxItem Tag="128x64"  Content="128×64  — SSD1306 (standardowy)" IsSelected="True"/>
                                <ComboBoxItem Tag="128x55"  Content="128×55  — Projekt iBinkos"/>
                                <ComboBoxItem Tag="128x32"  Content="128×32  — SSD1306 (mały)"/>
                                <ComboBoxItem Tag="64x48"   Content="64×48   — SSD1306 (Wemos D1 Mini)"/>
                                <ComboBoxItem Tag="96x16"   Content="96×16   — SSD1306 (paskowy)"/>
                                <ComboBoxItem Tag="72x40"   Content="72×40   — SSD1306 (okrągły)"/>
                                <ComboBoxItem Tag="128x128" Content="128×128 — SH1107 / SSD1327"/>
                                <ComboBoxItem Tag="64x128"  Content="64×128  — SH1107 (pionowy)"/>
                                <ComboBoxItem Tag="256x64"  Content="256×64  — SSD1322 (szeroki)"/>
                                <ComboBoxItem Tag="84x48"   Content="84×48   — Nokia 5110 (PCD8544)"/>
                                <ComboBoxItem Tag="custom"  Content="✏ Własny rozmiar..."/>
                            </ComboBox>

                            <!-- Panel własnego rozmiaru -->
                            <StackPanel x:Name="CustomSizePanel" Visibility="Collapsed" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomWidthBox" Grid.Column="0"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11"
                                         Text="128" ToolTip="Szerokość (px)"/>
                                    <TextBlock Grid.Column="1" Text="×" Foreground="#606060"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="CustomHeightBox" Grid.Column="2"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11"
                                         Text="64" ToolTip="Wysokość (px)"/>
                                    <Button Grid.Column="4" Content="Zastosuj"
                                        Style="{StaticResource PanelBtn}"
                                        FontSize="10" Padding="8,2"
                                        Click="CustomSize_Apply_Click"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="Nazwa zmiennej C:"
                                   Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <TextBox x:Name="VarNameBox" Text="mybitmap1"
                                 Style="{StaticResource DarkTB}"
                                 FontFamily="Consolas" FontSize="11"
                                 TextChanged="VarName_Changed"/>

                            <CheckBox x:Name="ShowGridChk" Content="Siatka 8px (granica bajtu)"
                                  IsChecked="True" Style="{StaticResource DarkCB}"
                                  Checked="Grid_Changed" Unchecked="Grid_Changed"/>
                            <CheckBox x:Name="ShowMinorChk" Content="Siatka pikseli 1px"
                                  IsChecked="True" Style="{StaticResource DarkCB}"
                                  Checked="Grid_Changed" Unchecked="Grid_Changed"/>

                        </StackPanel>

                        <!-- Coord display — widoczny zawsze -->
                        <Border Margin="0,10,0,0" Background="#111111"
                                BorderBrush="#2A2A2A" BorderThickness="1"
                                CornerRadius="5" Padding="8,5">
                            <TextBlock x:Name="CoordLabel" Text="—"
                                       Foreground="#30CC88"
                                       FontFamily="Consolas" FontSize="10"/>
                        </Border>

                        <!-- Tool hint -->
                        <Border Margin="0,6,0,0" Background="#111111"
                                BorderBrush="#2A2A2A" BorderThickness="1"
                                CornerRadius="5" Padding="8,5">
                            <TextBlock x:Name="ToolHintLabel"
                                       Text="✏ Ołówek — LPM rysuj, PPM gumka"
                                       Foreground="#707070"
                                       FontSize="9" TextWrapping="Wrap"/>
                        </Border>

                        <!-- ═══ OPCJE NARZĘDZIA ═══ -->
                        <Border x:Name="ToolOptionsSection" Visibility="Collapsed"
                                Margin="0,10,0,0" Background="#111518"
                                BorderBrush="#2A3A4A" BorderThickness="1"
                                CornerRadius="5" Padding="10,8">
                            <StackPanel>
                                <TextBlock x:Name="ToolOptionsSectionTitle"
                                           Text="OPCJE NARZĘDZIA"
                                           Style="{StaticResource SectLbl}"
                                           Foreground="#5588EE" Margin="0,0,0,8"/>

                                <!-- ── Tekst ── -->
                                <StackPanel x:Name="TextToolOptions" Visibility="Collapsed">
                                    <TextBlock Text="Czcionka:" Foreground="#707070"
                                               FontSize="10" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="FontFamilyBox"
                                              Style="{StaticResource DarkCombo}"
                                              Margin="0,0,0,8"
                                              SelectionChanged="TextOption_Changed">
                                        <ComboBoxItem Content="Consolas" IsSelected="True"/>
                                        <ComboBoxItem Content="Arial"/>
                                        <ComboBoxItem Content="Arial Narrow"/>
                                        <ComboBoxItem Content="Arial Black"/>
                                        <ComboBoxItem Content="Times New Roman"/>
                                        <ComboBoxItem Content="Courier New"/>
                                        <ComboBoxItem Content="Segoe UI"/>
                                        <ComboBoxItem Content="Segoe UI Black"/>
                                        <ComboBoxItem Content="Verdana"/>
                                        <ComboBoxItem Content="Tahoma"/>
                                        <ComboBoxItem Content="Impact"/>
                                        <ComboBoxItem Content="Trebuchet MS"/>
                                        <ComboBoxItem Content="Georgia"/>
                                        <ComboBoxItem Content="Palatino Linotype"/>
                                        <ComboBoxItem Content="Calibri"/>
                                        <ComboBoxItem Content="Cambria"/>
                                        <ComboBoxItem Content="Lucida Console"/>
                                        <ComboBoxItem Content="Lucida Sans Unicode"/>
                                        <ComboBoxItem Content="MS Gothic"/>
                                        <ComboBoxItem Content="Terminal"/>
                                    </ComboBox>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rozmiar:" Foreground="#707070"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <ComboBox x:Name="FontSizeBox" Grid.Column="1"
                                                  Style="{StaticResource DarkCombo}"
                                                  SelectionChanged="TextOption_Changed">
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8" IsSelected="True"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="20"/>
                                            <ComboBoxItem Content="24"/>
                                            <ComboBoxItem Content="32"/>
                                        </ComboBox>
                                        <ToggleButton x:Name="BoldBtn" Grid.Column="2"
                                                      Content="B" Width="28" Height="22"
                                                      FontWeight="Bold" FontSize="11"
                                                      Margin="6,0,3,0"
                                                      Checked="TextOption_Changed"
                                                      Unchecked="TextOption_Changed"
                                                      Background="#222" Foreground="#AAA"
                                                      BorderBrush="#444"/>
                                        <ToggleButton x:Name="ItalicBtn" Grid.Column="3"
                                                      Content="I" Width="28" Height="22"
                                                      FontStyle="Italic" FontSize="11"
                                                      Checked="TextOption_Changed"
                                                      Unchecked="TextOption_Changed"
                                                      Background="#222" Foreground="#AAA"
                                                      BorderBrush="#444"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Kolor:" Foreground="#707070"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <RadioButton x:Name="ColorWhite" GroupName="TxtColor"
                                                     IsChecked="True"
                                                     Checked="TextOption_Changed"
                                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14" Height="14" Background="White"
                                                        BorderBrush="#555" BorderThickness="1" Margin="0,0,4,0"/>
                                                <TextBlock Text="Biały" Foreground="#AAA" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="ColorBlack" GroupName="TxtColor"
                                                     Checked="TextOption_Changed"
                                                     VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14" Height="14" Background="Black"
                                                        BorderBrush="#555" BorderThickness="1" Margin="0,0,4,0"/>
                                                <TextBlock Text="Czarny" Foreground="#AAA" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ── Ołówek ── -->
                                <StackPanel x:Name="PencilToolOptions" Visibility="Collapsed">
                                    <TextBlock Text="Rozmiar końcówki:" Foreground="#707070"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Slider x:Name="PencilSizeSlider"
                                            Minimum="1" Maximum="20" Value="1"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="PencilSize_Changed"/>
                                    <TextBlock x:Name="PencilSizeLabel"
                                               Text="1 px" Foreground="#5588EE"
                                               FontSize="10" HorizontalAlignment="Right"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Kształt końcówki:" Foreground="#707070"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="BrushShapeCircle" GroupName="PencilShape"
                                                     IsChecked="True" Foreground="#AAA" FontSize="10"
                                                     Checked="BrushShape_Changed" Margin="0,0,10,0">
                                            <TextBlock Text="● Kółko" Foreground="#AAA" FontSize="10"/>
                                        </RadioButton>
                                        <RadioButton x:Name="BrushShapeSquare" GroupName="PencilShape"
                                                     Foreground="#AAA" FontSize="10"
                                                     Checked="BrushShape_Changed">
                                            <TextBlock Text="■ Kwadrat" Foreground="#AAA" FontSize="10"/>
                                        </RadioButton>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ── Gumka ── -->
                                <StackPanel x:Name="EraserToolOptions" Visibility="Collapsed">
                                    <TextBlock Text="Rozmiar gumki:" Foreground="#707070"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Slider x:Name="EraserSizeSlider"
                                            Minimum="1" Maximum="20" Value="1"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="EraserSize_Changed"/>
                                    <TextBlock x:Name="EraserSizeLabel"
                                               Text="1 px" Foreground="#5588EE"
                                               FontSize="10" HorizontalAlignment="Right"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="Kształt gumki:" Foreground="#707070"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="EraserShapeCircle" GroupName="EraserShape"
                                                     IsChecked="True" Foreground="#AAA" FontSize="10"
                                                     Checked="BrushShape_Changed" Margin="0,0,10,0">
                                            <TextBlock Text="● Kółko" Foreground="#AAA" FontSize="10"/>
                                        </RadioButton>
                                        <RadioButton x:Name="EraserShapeSquare" GroupName="EraserShape"
                                                      Foreground="#AAA" FontSize="10"
                                                      Checked="BrushShape_Changed">
                                             <TextBlock Text="■ Kwadrat" Foreground="#AAA" FontSize="10"/>
                                         </RadioButton>
                                     </StackPanel>
                                 </StackPanel>

                                 <!-- ── Zaznaczanie (tylko animacja) ── -->
                                 <StackPanel x:Name="SelectionToolOptions" Visibility="Collapsed">
                                     <Rectangle Height="1" Fill="#2A3A4A" Margin="0,0,0,8"/>
                                     <TextBlock Text="Synchronizacja klatek:" Foreground="#707070"
                                                FontSize="10" Margin="0,0,0,6"/>
                                     <CheckBox x:Name="SyncSelectionChk"
                                               Checked="SyncSelection_Changed"
                                               Unchecked="SyncSelection_Changed"
                                               VerticalAlignment="Center"
                                               ToolTip="Ta sama operacja zaznaczenia zostanie zastosowana na każdej klatce animacji (każda klatka używa własnych pikseli)">
                                         <StackPanel Orientation="Horizontal">
                                             <TextBlock Text="⛶" Margin="0,0,5,0" FontSize="12"
                                                        Foreground="#44BBFF"/>
                                             <TextBlock Text="Sync klatek" Foreground="#44BBFF"
                                                        FontSize="11"/>
                                         </StackPanel>
                                     </CheckBox>
                                     <TextBlock Text="Przesuń / obróć / skaluj zaznaczenie na wszystkich klatkach jednocześnie."
                                                Foreground="#556677" FontSize="9"
                                                TextWrapping="Wrap" Margin="0,5,0,0"/>
                                 </StackPanel>

                            </StackPanel>
                        </Border>

                        <!-- Przycisk zapisu szablonu (widoczny tylko dla zakładek edytora) -->
                        <StackPanel x:Name="SaveTemplatePanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,8"/>
                            <Button Content="✔ Zapisz szablon" Click="SaveTemplate_Click"
                                    Style="{StaticResource PanelBtn}"
                                    Foreground="#2EE89A" BorderBrush="#28D09A"
                                    Background="#0D2820"/>
                        </StackPanel>

                        <!-- Panel animacji — rozmiar wspólny dla wszystkich klatek -->
                        <StackPanel x:Name="AnimSettingsPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,8"/>
                            <TextBlock Text="ANIMACJA — WSPÓLNY EKRAN" Style="{StaticResource SectLbl}"
                                       Foreground="#FFCC00" Margin="0,0,0,6"/>
                            <TextBlock Text="Rozmiar ekranu (wszystkie klatki):"
                                       Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="AnimOledCombo"
                                      Style="{StaticResource DarkCombo}"
                                      Margin="0,0,0,6"
                                      SelectionChanged="AnimOledCombo_Changed">
                                <ComboBoxItem Tag="128x64"  Content="128×64  — SSD1306" IsSelected="True"/>
                                <ComboBoxItem Tag="128x55"  Content="128×55  — Projekt iBinkos"/>
                                <ComboBoxItem Tag="128x32"  Content="128×32  — SSD1306 (mały)"/>
                                <ComboBoxItem Tag="64x48"   Content="64×48   — SSD1306 (Wemos)"/>
                                <ComboBoxItem Tag="96x16"   Content="96×16   — SSD1306 (paskowy)"/>
                                <ComboBoxItem Tag="72x40"   Content="72×40   — SSD1306 (okrągły)"/>
                                <ComboBoxItem Tag="128x128" Content="128×128 — SH1107"/>
                                <ComboBoxItem Tag="64x128"  Content="64×128  — SH1107 (pionowy)"/>
                                <ComboBoxItem Tag="256x64"  Content="256×64  — SSD1322 (szeroki)"/>
                                <ComboBoxItem Tag="84x48"   Content="84×48   — Nokia 5110"/>
                                <ComboBoxItem Tag="custom"  Content="✏ Własny rozmiar..."/>
                            </ComboBox>

                            <!-- Panel własnego rozmiaru animacji -->
                            <StackPanel x:Name="AnimCustomSizePanel" Visibility="Collapsed" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AnimCustomWidthBox" Grid.Column="0"
                                             Style="{StaticResource DarkTB}"
                                             FontFamily="Consolas" FontSize="11"
                                             Text="128" ToolTip="Szerokość (px)"/>
                                    <TextBlock Grid.Column="1" Text="×" Foreground="#606060"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBox x:Name="AnimCustomHeightBox" Grid.Column="2"
                                             Style="{StaticResource DarkTB}"
                                             FontFamily="Consolas" FontSize="11"
                                             Text="64" ToolTip="Wysokość (px)"/>
                                    <Button Grid.Column="4" Content="Zastosuj"
                                            Style="{StaticResource PanelBtn}"
                                            FontSize="10" Padding="8,2"
                                            Click="AnimCustomSize_Apply_Click"/>
                                </Grid>
                            </StackPanel>
                            <TextBlock Text="Nazwa animacji:" Foreground="#707070"
                                       FontSize="10" Margin="0,0,0,3"/>
                            <TextBox x:Name="AnimNameBox" Text="anim1"
                                     Style="{StaticResource DarkTB}"
                                     FontFamily="Consolas" FontSize="11"
                                     TextChanged="AnimName_Changed"/>
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,8,0,8"/>
                            <TextBlock Text="Eksport animacji do pliku .h:"
                                       Foreground="#707070" FontSize="10" Margin="0,0,0,6"
                                       TextWrapping="Wrap"/>
                            <Button Content="💾 Eksport animacji .h"
                                    Style="{StaticResource PanelBtn}"
                                    Click="AnimExportFromPanel_Click"
                                    Foreground="#FFB84D" BorderBrush="#CC8833"
                                    Background="#1A1200"/>

                            <!-- ── TWEEN ──────────────────────────────────── -->
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,12,0,8"/>
                            <TextBlock Text="〜  TWEEN — AUTO KLATKI"
                                       Foreground="#88BBFF" FontSize="10" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Od klatki:" Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="TweenFromCombo"
                                      Style="{StaticResource DarkCombo}" Margin="0,0,0,6"/>
                            <TextBlock Text="Do klatki:" Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <ComboBox x:Name="TweenToCombo"
                                      Style="{StaticResource DarkCombo}" Margin="0,0,0,8"/>
                            <TextBlock Text="Easing:" Foreground="#707070" FontSize="10" Margin="0,0,0,4"/>
                            <StackPanel Margin="0,0,0,8">
                                <RadioButton x:Name="TweenLinear" Content="Linear"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenEasing" IsChecked="True"
                                             Margin="0,0,0,2"/>
                                <RadioButton x:Name="TweenEaseIn" Content="Ease In"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenEasing" Margin="0,0,0,2"/>
                                <RadioButton x:Name="TweenEaseOut" Content="Ease Out"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenEasing" Margin="0,0,0,2"/>
                                <RadioButton x:Name="TweenEaseBoth" Content="Ease In+Out (S)"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenEasing"/>
                            </StackPanel>
                            <TextBlock Text="Tryb morfingu:" Foreground="#707070" FontSize="10" Margin="0,0,0,4"/>
                            <StackPanel Margin="0,0,0,8">
                                <RadioButton x:Name="TweenMorphTransScale"
                                             Content="↔↕ Translate + Scale"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenMorph" IsChecked="True"
                                             Margin="0,0,0,2"
                                             ToolTip="Przesuwa i skaluje obiekt — najlepszy wynik (zalecane)"/>
                                <RadioButton x:Name="TweenMorphTranslate"
                                             Content="↔ Tylko Translate"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenMorph" Margin="0,0,0,2"
                                             ToolTip="Przesuwa obiekt z A do B bez zmiany rozmiaru"/>
                                <RadioButton x:Name="TweenMorphScale"
                                             Content="↕ Tylko Scale"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenMorph" Margin="0,0,0,2"
                                             ToolTip="Skaluje obiekt do rozmiaru B bez przesunięcia centrum"/>
                                <RadioButton x:Name="TweenMorphDissolve"
                                             Content="░ Dissolve (Bayer)"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="TweenMorph"
                                             ToolTip="Rozpuszczanie piksel-po-pikselu z ditherowanym progiem (Bayer 4×4)"/>
                            </StackPanel>
                            <TextBlock Text="Liczba klatek do wygenerowania:"
                                       Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TweenFramesBox"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11"
                                         Text="3" Grid.Column="0"/>
                                <TextBlock Grid.Column="2" Text="klatek"
                                           Foreground="#555" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Button Content="✨ Generuj klatki pośrednie"
                                    Style="{StaticResource PanelBtn}"
                                    Click="TweenGenerate_Click"
                                    Foreground="#88BBFF" BorderBrush="#336699"
                                    Background="#0A0F1A"/>
                        </StackPanel>

                        <!-- ── PANEL SPRITE (prawy panel) ─────────────────── -->
                        <StackPanel x:Name="SpriteSettingsPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,8"/>
                            <TextBlock Text="🕹️  SPRITE — USTAWIENIA RUCHU"
                                       Style="{StaticResource SectLbl}"
                                       Foreground="#FF9900" Margin="0,0,0,6"/>

                            <TextBlock Text="Nazwa sprite'a:" Foreground="#707070"
                                       FontSize="10" Margin="0,0,0,3"/>
                            <TextBox x:Name="SpriteNameBox" Text="mySprite"
                                     Style="{StaticResource DarkTB}"
                                     FontFamily="Consolas" FontSize="11"
                                     TextChanged="SpriteName_Changed"/>

                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,8,0,8"/>

                            <TextBlock Text="Pozycja startowa:" Foreground="#707070"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X:" Grid.Column="0" Foreground="#666"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="SpriteStartXBox" Grid.Column="1"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11" Text="0"
                                         TextChanged="SpriteMotion_Changed"/>
                                <TextBlock Text="Y:" Grid.Column="3" Foreground="#666"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="SpriteStartYBox" Grid.Column="4"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11" Text="16"
                                         TextChanged="SpriteMotion_Changed"/>
                            </Grid>

                            <TextBlock Text="Pozycja końcowa:" Foreground="#707070"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X:" Grid.Column="0" Foreground="#666"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="SpriteEndXBox" Grid.Column="1"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11" Text="96"
                                         TextChanged="SpriteMotion_Changed"/>
                                <TextBlock Text="Y:" Grid.Column="3" Foreground="#666"
                                           FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="SpriteEndYBox" Grid.Column="4"
                                         Style="{StaticResource DarkTB}"
                                         FontFamily="Consolas" FontSize="11" Text="16"
                                         TextChanged="SpriteMotion_Changed"/>
                            </Grid>

                            <TextBlock Text="Opóźnienie (ms / klatka):"
                                       Foreground="#707070" FontSize="10" Margin="0,0,0,3"/>
                            <TextBox x:Name="SpriteDelayBox" Text="16"
                                     Style="{StaticResource DarkTB}"
                                     FontFamily="Consolas" FontSize="11"
                                     Margin="0,0,0,8"
                                     TextChanged="SpriteMotion_Changed"/>

                            <TextBlock Text="Tryb pętli:" Foreground="#707070"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <StackPanel Margin="0,0,0,8">
                                <RadioButton x:Name="SpriteLoopOnce"  Content="Raz (Once)"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="SpriteLoop" Margin="0,0,0,2"
                                             Checked="SpriteLoop_Changed"/>
                                <RadioButton x:Name="SpriteLoopLoop"  Content="Pętla (Loop)"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="SpriteLoop" IsChecked="True"
                                             Margin="0,0,0,2"
                                             Checked="SpriteLoop_Changed"/>
                                <RadioButton x:Name="SpriteLoopBounce" Content="Odbijanie (Bounce)"
                                             Foreground="#AAAAAA" FontSize="10"
                                             GroupName="SpriteLoop"
                                             Checked="SpriteLoop_Changed"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,8"/>
                            <Button Content="💾 Eksport sprite .h"
                                    Style="{StaticResource PanelBtn}"
                                    Click="SpriteExportFromPanel_Click"
                                    Foreground="#FF9900" BorderBrush="#AA6600"
                                    Background="#1A0D00"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Code output -->
                    <Grid x:Name="CodeSection" Grid.Row="1" Margin="0,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Code header -->
                        <TextBlock Text="KOD C · MSB-FIRST · PROGMEM"
                                   Style="{StaticResource SectLbl}" Margin="12,0,8,4"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="CodeBodyBorder"
                                Grid.Row="1"
                                BorderBrush="#2A2A2A" BorderThickness="1,1,1,1">
                            <TextBox x:Name="CodeOutput"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="#0C0C0C"
                                     Foreground="#38CC38"
                                     FontFamily="Consolas"
                                     FontSize="8.5"
                                     BorderThickness="0"
                                     Padding="8"/>
                        </Border>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel x:Name="CodeActionPanel" Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="12,10">
                        <Button Content="📋 Kopiuj kod" Click="CopyCode_Click"
                                Style="{StaticResource PanelBtn}" Margin="0,0,8,0"
                                Width="110"/>
                        <Button Content="💾 Zapisz .h" Click="SaveFile_Click"
                                Style="{StaticResource PanelBtn}"
                                Width="110"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="3" Background="#111111"
                BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Text="Gotowy — wybierz narzędzie i rysuj na canvasie"
                           Foreground="#606060" FontSize="10"
                           Padding="12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="LPM = rysuj  ·  PPM = gumka  ·  Scroll = zoom"
                           Foreground="#484848" FontSize="10"
                           Padding="12,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
