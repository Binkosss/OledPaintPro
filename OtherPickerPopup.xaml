<Window x:Class="OledPaintPro.OtherPickerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        Width="318"
        ResizeMode="NoResize"
        Background="Transparent"
        Deactivated="Window_Deactivated">

    <!-- Styl separatora dla ContextMenu -->
    <Window.Resources>
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="#333"
                                Margin="0,4,0,4"
                                HorizontalAlignment="Stretch"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#141414" BorderBrush="#3A3A3A" BorderThickness="1"
            CornerRadius="6" Padding="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel Width="286">
            <DockPanel Margin="0,0,0,6" LastChildFill="True">
                <Button Content="＋ Nowa Grafika" DockPanel.Dock="Right"
                        Height="17" Padding="6,-2,8,0" FontSize="10" Cursor="Hand"
                        Background="#0D2820" Foreground="#2EE89A"
                        BorderBrush="#28D09A" BorderThickness="1"
                        Click="NewOther_Click" Width="90"/>
                <TextBlock Text="BIBLIOTEKA INNE" Foreground="#505050"
                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>
            <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,6"/>
            <WrapPanel x:Name="ThumbPanel" Width="264"/>
            <TextBlock x:Name="EmptyLabel"
                       Text="Brak szablonów — kliknij ＋ aby dodać"
                       Foreground="#404040" FontSize="9" TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</Window>
