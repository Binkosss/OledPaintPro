<UserControl x:Class="OledPaintPro.PixelCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#141414">
    <Grid>
        <!-- Canvas -->
        <Border Background="#1C1C1C">
            <ScrollViewer x:Name="CanvasScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#1C1C1C">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <Border BorderBrush="#0B0E45" BorderThickness="4" CornerRadius="6" Background="#000000">
                        <Border.Effect>
                            <DropShadowEffect Color="#101363" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>
                        <!-- Grid: CanvasImage + nakładka tekstowa -->
                        <Grid x:Name="CanvasGrid">
                            <Image x:Name="CanvasImage"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Cursor="Cross"/>
                            <!-- Nakładka: TextBox podczas edycji tekstu -->
                            <Canvas x:Name="TextOverlay"
                                    IsHitTestVisible="False"
                                    Width="{Binding ActualWidth, ElementName=CanvasImage}"
                                    Height="{Binding ActualHeight, ElementName=CanvasImage}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Koordynaty — overlay lewy dół (ukryty gdy kontrolka osadzona w MainWindow) -->
        <Border x:Name="CoordOverlay" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="8" Background="#111111" BorderBrush="#2A2A2A"
                BorderThickness="1" CornerRadius="4" Padding="6,3"
                IsHitTestVisible="False" Visibility="Collapsed">
            <TextBlock x:Name="CoordLabel" Text="—"
                       Foreground="#30CC88" FontFamily="Consolas" FontSize="9"/>
        </Border>

        <!-- Ukryte pola rozmiaru (używane przez kod przy zmianie przez OledCombo) -->
        <StackPanel Visibility="Collapsed">
            <TextBox x:Name="WidthBox"  Text="128" TextChanged="Size_Changed"/>
            <TextBox x:Name="HeightBox" Text="64"  TextChanged="Size_Changed"/>
        </StackPanel>
    </Grid>
</UserControl>
