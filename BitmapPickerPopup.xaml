<Window x:Class="OledPaintPro.BitmapPickerPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        Width="360"
        MaxHeight="500"
        ResizeMode="NoResize"
        Background="Transparent"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- Ciemny styl suwaka ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="#1A1A1A" Width="8" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#141414"/>
        </Style>
    </Window.Resources>

    <Border Background="#141414" BorderBrush="#3A3A3A" BorderThickness="1"
            CornerRadius="6" Padding="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel Width="328">
            <!-- Nagłówek -->
            <DockPanel Margin="0,0,0,4" LastChildFill="True">
                <Button Content="⬆ Załaduj" DockPanel.Dock="Right"
                        Height="17" Padding="6,-2,8,0" FontSize="10" Cursor="Hand"
                        Background="#0D1820" Foreground="#2E9AE8"
                        BorderBrush="#28A0D0" BorderThickness="1"
                        Click="NewBitmap_Click" Width="70"/>
                <TextBlock Text="BIBLIOTEKA BITMAP" Foreground="#505050"
                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Filtr -->
            <TextBox x:Name="FilterBox" Height="20" FontSize="10" Margin="0,0,0,6"
                     Background="#1A1A1A" Foreground="#AAD4FF" BorderBrush="#333" BorderThickness="1"
                     Padding="4,1" VerticalContentAlignment="Center"
                     TextChanged="FilterBox_TextChanged"/>

            <!-- Zakładki grup -->
            <!-- ZMIANA: Dodano ControlTemplate dla TabControl i TabItem,
                 bo domyślny WPF template ignoruje Background i używa SystemColors.ControlBrush (białe).
                 ControlTemplate TabControl wymusza ciemne tło #141414 w obszarze zawartości.
                 ControlTemplate TabItem wymusza dark theme z hover/selected triggers. -->
            <TabControl x:Name="GroupTabs"
                        Background="#141414"
                        BorderBrush="#2A2A2A" BorderThickness="1"
                        Foreground="#AAD4FF"
                        MaxHeight="400">
                <TabControl.Resources>

                    <!-- ZMIANA: Pełny ControlTemplate dla TabControl —
                         bez tego WPF rysuje biały/szary panel zawartości niezależnie od Background -->
                    <Style TargetType="TabControl">
                        <Setter Property="Background"  Value="#141414"/>
                        <Setter Property="BorderBrush" Value="#2A2A2A"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Pasek zakładek -->
                                        <TabPanel Grid.Row="0"
                                                  IsItemsHost="True"
                                                  Background="Transparent"/>

                                        <!-- Obszar zawartości — ZMIANA: TemplateBinding Background zamiast SystemColors -->
                                        <Border Grid.Row="1"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter ContentSource="SelectedContent"
                                                              Margin="4"/>
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- ZMIANA: Pełny ControlTemplate dla TabItem —
                         bez tego settery Background/Foreground są ignorowane przez domyślny template -->
                    <Style TargetType="TabItem">
                        <Setter Property="Background"  Value="#1A1A1A"/>
                        <Setter Property="Foreground"  Value="#888888"/>
                        <Setter Property="BorderBrush" Value="#2A2A2A"/>
                        <Setter Property="FontSize"    Value="10"/>
                        <Setter Property="Padding"     Value="8,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            Margin="0,0,2,0"
                                            CornerRadius="3,3,0,0">
                                        <ContentPresenter x:Name="TabContent"
                                                          ContentSource="Header"
                                                          Margin="{TemplateBinding Padding}"
                                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- ZMIANA: Aktywna zakładka — tło #1C2830, tekst #55CCFF -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#1C2830"/>
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2A6080"/>
                                            <Setter TargetName="TabContent" Property="TextBlock.Foreground" Value="#55CCFF"/>
                                        </Trigger>
                                        <!-- Hover na nieaktywnej zakładce -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected"  Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="TabBorder" Property="Background" Value="#222222"/>
                                            <Setter TargetName="TabContent" Property="TextBlock.Foreground" Value="#AAAAAA"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                </TabControl.Resources>
            </TabControl>

            <TextBlock x:Name="EmptyUserLabel"
                       Text="Brak własnych bitmap — kliknij ＋ aby dodać"
                       Foreground="#404040" FontSize="9" TextWrapping="Wrap"
                       Margin="0,4,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>
