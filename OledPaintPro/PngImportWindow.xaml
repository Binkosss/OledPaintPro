<Window x:Class="OledPaintPro.PngImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import PNG → Bitmapa OLED"
        Width="780" Height="560"
        MinWidth="680" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        Foreground="#CCCCCC">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Margin"       Value="0,10,0,4"/>
        </Style>
        <Style x:Key="DarkBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#1A1A1A"/>
            <Setter Property="Foreground"       Value="#CCFFCC"/>
            <Setter Property="BorderBrush"      Value="#333333"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="5,3"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="11"/>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Width"      Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="#1A1A1A" Width="8" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ PODGLĄD LEWO ═══ -->
        <Grid Grid.Column="0" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Nagłówek podglądu -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="PODGLĄD" Style="{StaticResource SectionLabel}" Margin="0,0,12,0"/>
                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="3" Padding="6,2">
                    <TextBlock x:Name="PreviewSizeLabel" Text="— × —" Foreground="#666" FontSize="9"/>
                </Border>
                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="3" Padding="6,2" Margin="4,0,0,0">
                    <TextBlock x:Name="OriginalSizeLabel" Text="Oryginał: —" Foreground="#444" FontSize="9"/>
                </Border>
            </StackPanel>

            <!-- Płótno podglądu -->
            <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#2A2A2A" BorderThickness="1"
                    CornerRadius="4" ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#0A0A0A">
                    <Grid x:Name="PreviewGrid" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Margin="16">
                        <!-- Szachownica tła (transparentność) -->
                        <Rectangle x:Name="CheckerBg" Fill="#1A1A1A"/>
                        <!-- Oryginalny PNG (półprzezroczysty) -->
                        <Image x:Name="OriginalImage"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Opacity="0.25"/>
                        <!-- Skonwertowana bitmapa B&W -->
                        <Image x:Name="PreviewImage"
                               Stretch="None"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- Suwak zoom podglądu -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555"/>
                <Slider x:Name="PreviewZoomSlider" Minimum="1" Maximum="8" Value="2" Width="120"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        ValueChanged="PreviewZoom_Changed" VerticalAlignment="Center"/>
                <TextBlock x:Name="PreviewZoomLabel" Text="2×" Margin="6,0,0,0"
                           Foreground="#666" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══ SEPARATOR ═══ -->
        <Rectangle Grid.Column="1" Grid.Row="0" Fill="#222222" Width="1" Margin="0,20"/>

        <!-- ═══ USTAWIENIA PRAWO ═══ -->
        <ScrollViewer Grid.Column="2" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8,0,0,0">

                <!-- NAZWA -->
                <TextBlock Text="NAZWA BITMAPY" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Style="{StaticResource DarkBox}"
                         TextChanged="Settings_Changed"/>

                <!-- ROZMIAR -->
                <TextBlock Text="ROZMIAR DOCELOWY" Style="{StaticResource SectionLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Szer." Foreground="#555" FontSize="9" Margin="0,0,0,2"/>
                        <TextBox x:Name="WidthBox" Style="{StaticResource DarkBox}"
                                 TextChanged="SizeBox_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Wys." Foreground="#555" FontSize="9" Margin="0,0,0,2"/>
                        <TextBox x:Name="HeightBox" Style="{StaticResource DarkBox}"
                                 TextChanged="SizeBox_Changed"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="LockAspect" Content="Zachowaj proporcje" Margin="0,5,0,0"
                          Foreground="#888" FontSize="10" IsChecked="True"
                          Checked="Settings_Changed" Unchecked="Settings_Changed"/>

                <!-- Presety -->
                <TextBlock Text="PRESETY" Style="{StaticResource SectionLabel}"/>
                <WrapPanel>
                    <Button Content="128×64" Tag="128,64"  Style="{StaticResource ActionBtn}"
                            Click="Preset_Click" Margin="0,0,4,4"
                            Background="#1A1A1A" Foreground="#888" BorderBrush="#333" Padding="8,4"/>
                    <Button Content="64×64"  Tag="64,64"   Style="{StaticResource ActionBtn}"
                            Click="Preset_Click" Margin="0,0,4,4"
                            Background="#1A1A1A" Foreground="#888" BorderBrush="#333" Padding="8,4"/>
                    <Button Content="32×32"  Tag="32,32"   Style="{StaticResource ActionBtn}"
                            Click="Preset_Click" Margin="0,0,4,4"
                            Background="#1A1A1A" Foreground="#888" BorderBrush="#333" Padding="8,4"/>
                    <Button Content="16×16"  Tag="16,16"   Style="{StaticResource ActionBtn}"
                            Click="Preset_Click" Margin="0,0,4,4"
                            Background="#1A1A1A" Foreground="#888" BorderBrush="#333" Padding="8,4"/>
                </WrapPanel>

                <!-- PRÓG BINARYZACJI -->
                <TextBlock Text="PRÓG BINARYZACJI" Style="{StaticResource SectionLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="ThresholdSlider" Grid.Column="0"
                            Minimum="0" Maximum="255" Value="128"
                            VerticalAlignment="Center"
                            ValueChanged="Settings_Changed"/>
                    <TextBlock x:Name="ThresholdLabel" Grid.Column="1"
                               Text="128" Foreground="#CCFFCC" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- ALGORYTM -->
                <TextBlock Text="ALGORYTM KONWERSJI" Style="{StaticResource SectionLabel}"/>
                <StackPanel>
                    <RadioButton x:Name="AlgoThreshold"   Content="Próg (Threshold)"         GroupName="Algo"
                                 Foreground="#AAA" FontSize="10" IsChecked="True"
                                 Checked="Settings_Changed" Margin="0,0,0,3"/>
                    <RadioButton x:Name="AlgoFloyd"       Content="Floyd-Steinberg Dithering" GroupName="Algo"
                                 Foreground="#AAA" FontSize="10"
                                 Checked="Settings_Changed" Margin="0,0,0,3"/>
                    <RadioButton x:Name="AlgoBayer"       Content="Ordered (Bayer 4×4)"       GroupName="Algo"
                                 Foreground="#AAA" FontSize="10"
                                 Checked="Settings_Changed" Margin="0,0,0,3"/>
                    <RadioButton x:Name="AlgoAtkinson"    Content="Atkinson Dithering"        GroupName="Algo"
                                 Foreground="#AAA" FontSize="10"
                                 Checked="Settings_Changed"/>
                </StackPanel>

                <!-- SKALOWANIE -->
                <TextBlock Text="INTERPOLACJA SKALOWANIA" Style="{StaticResource SectionLabel}"/>
                <StackPanel>
                    <RadioButton x:Name="ScaleNearest"  Content="Nearest Neighbor (pikselowy)" GroupName="Scale"
                                 Foreground="#AAA" FontSize="10" IsChecked="True"
                                 Checked="Settings_Changed" Margin="0,0,0,3"/>
                    <RadioButton x:Name="ScaleBilinear" Content="Bilinear (wygładzony)"         GroupName="Scale"
                                 Foreground="#AAA" FontSize="10"
                                 Checked="Settings_Changed" Margin="0,0,0,3"/>
                    <RadioButton x:Name="ScaleBicubic"  Content="Bicubic (najlepsza jakość)"    GroupName="Scale"
                                 Foreground="#AAA" FontSize="10"
                                 Checked="Settings_Changed"/>
                </StackPanel>

                <!-- OPCJE DODATKOWE -->
                <TextBlock Text="OPCJE" Style="{StaticResource SectionLabel}"/>
                <CheckBox x:Name="InvertCheck" Content="Odwróć kolory (biały↔czarny)"
                          Foreground="#888" FontSize="10"
                          Checked="Settings_Changed" Unchecked="Settings_Changed" Margin="0,0,0,4"/>
                <CheckBox x:Name="OverlayCheck" Content="Pokaż oryginał w tle (25%)"
                          Foreground="#888" FontSize="10" IsChecked="True"
                          Checked="Overlay_Changed" Unchecked="Overlay_Changed"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ PRZYCISKI DÓŁ ═══ -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusLabel" Grid.Column="0"
                       Text="" Foreground="#555" FontSize="10"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="OpenEditorBtn" Content="✏ Otwórz w edytorze"
                        Style="{StaticResource ActionBtn}" Margin="0,0,8,0"
                        Background="#0D2820" Foreground="#44FF88"
                        BorderBrush="#28AA55"
                        Click="OpenEditor_Click"/>
                <Button x:Name="SaveLibraryBtn" Content="💾 Zapisz w bibliotece"
                        Style="{StaticResource ActionBtn}" Margin="0,0,8,0"
                        Background="#0D1828" Foreground="#44AAFF"
                        BorderBrush="#2255AA"
                        Click="SaveLibrary_Click"/>
                <Button Content="Anuluj"
                        Style="{StaticResource ActionBtn}"
                        Background="#1A1A1A" Foreground="#666"
                        BorderBrush="#333"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
