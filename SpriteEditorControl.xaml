<UserControl x:Class="OledPaintPro.SpriteEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#141414">
    <UserControl.Resources>
        <!-- ── Style lokalny HdrBtn (taki sam jak w MainWindow) ─────────── -->
        <Style x:Key="HdrBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#AAAAAA"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="8,5"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#333" BorderThickness="0"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- główna treść -->
            <RowDefinition Height="Auto"/>  <!-- pasek statusu -->
        </Grid.RowDefinitions>

        <!-- ══ TOOLBAR SPRITE ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,4">

                <!-- Dodaj klatkę sprite'a -->
                <Button x:Name="AddFrameBtn" Click="AddFrame_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,4,0"
                        ToolTip="Dodaj nową klatkę sprite'a">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" Margin="0,-1,4,0" FontSize="14" Foreground="#FF9900"/>
                        <TextBlock Text="Klatka" Foreground="#FF9900"/>
                    </StackPanel>
                </Button>

                <!-- Duplikuj -->
                <Button x:Name="DupFrameBtn" Click="DupFrame_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,4,0"
                        ToolTip="Duplikuj klatkę">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⧉" Margin="0,0,4,0" Foreground="#88BBFF"/>
                        <TextBlock Text="Duplikuj" Foreground="#88BBFF"/>
                    </StackPanel>
                </Button>

                <!-- Usuń -->
                <Button x:Name="DelFrameBtn" Click="DelFrame_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,10,0"
                        ToolTip="Usuń klatkę">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" Margin="0,0,4,0" Foreground="#FF6666"/>
                        <TextBlock Text="Usuń" Foreground="#FF6666"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Background="#333" Margin="0,4,10,4"/>

                <!-- Strzałki kolejności -->
                <Button x:Name="MoveLeftBtn" Click="MoveLeft_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,2,0"
                        ToolTip="Przesuń klatkę w lewo">
                    <TextBlock Text="◀" Foreground="#888"/>
                </Button>
                <Button x:Name="MoveRightBtn" Click="MoveRight_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,10,0"
                        ToolTip="Przesuń klatkę w prawo">
                    <TextBlock Text="▶" Foreground="#888"/>
                </Button>

                <Border Width="1" Background="#333" Margin="0,4,10,4"/>

                <!-- PLAY podgląd -->
                <Button x:Name="PlayBtn" Click="Play_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,2,0"
                        ToolTip="Podgląd ruchu sprite'a (Spacja)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PlayIcon" Text="▶" Margin="0,0,4,0" Foreground="#FF9900"/>
                        <TextBlock x:Name="PlayLabel" Text="Play" Foreground="#FF9900"/>
                    </StackPanel>
                </Button>

                <!-- Loop -->
                <Button x:Name="LoopBtn" Click="Loop_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,10,0"
                        ToolTip="Pętla podglądu">
                    <TextBlock x:Name="LoopIcon" Text="🔁" FontSize="11"/>
                </Button>

                <!-- FPS -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="FPS:" Foreground="#666"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="FpsSlider" Minimum="1" Maximum="60" Value="10"
                            Width="80" VerticalAlignment="Center"
                            ValueChanged="FpsSlider_ValueChanged"
                            Background="Transparent"/>
                    <TextBlock x:Name="FpsLabel" Text="10"
                               Foreground="#FF9900" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0" Width="22"/>
                </StackPanel>

                <Border Width="1" Background="#333" Margin="0,4,10,4"/>

                <!-- OLED preview mini -->
                <Border Background="#000" BorderBrush="#333" BorderThickness="1"
                        CornerRadius="3" Padding="4,2" VerticalAlignment="Center" Margin="0,0,10,0"
                        ToolTip="Podgląd OLED (1:1)">
                    <Image x:Name="OledPreviewImage" Width="64" Height="32"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <!-- Eksport -->
                <Button x:Name="ExportBtn" Click="Export_Click"
                        Style="{StaticResource HdrBtn}" Margin="0,0,4,0"
                        ToolTip="Eksportuj sprite do pliku .h (include)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" Margin="0,-1,5,0" FontSize="12"/>
                        <TextBlock Text="Eksport .h" Foreground="#FF9900"/>
                    </StackPanel>
                </Button>

                <!-- Status -->
                <TextBlock x:Name="SpriteStatusLabel" Text="Klatka 1/1"
                           Foreground="#FF9900" FontFamily="Consolas" FontSize="10"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ GŁÓWNA TREŚĆ ════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="148" MinWidth="80" MaxWidth="260"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── FILMSTRIP klatek sprite'a ─────────────────────────────── -->
            <Border Grid.Column="0" Background="#111"
                    BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#1A1A1A" BorderBrush="#2A2A2A"
                            BorderThickness="0,0,0,1" Padding="8,5">
                        <TextBlock x:Name="FrameCountLabel" Text="Klatki: 1"
                                   Foreground="#555" FontFamily="Consolas" FontSize="10"/>
                    </Border>
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="FilmstripPanel"
                                    Orientation="Vertical" Margin="6,6,6,6"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="3" Background="#222"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ── EDYTOR KLATKI ───────────────────────────────────────── -->
            <Border Grid.Column="2" x:Name="EditorContainer" Background="#141414"/>

            <!-- ── PODGLĄD RUCHU (widoczny tylko podczas Play) ───────────── -->
            <Border Grid.Column="2" x:Name="PlayPreviewBorder"
                    Background="#141414" Visibility="Collapsed"
                    Panel.ZIndex="10">
                <Grid>
                    <Border Background="#1C1C1C">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="#1C1C1C">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Margin="20">
                                <Border BorderBrush="#451B0B" BorderThickness="4"
                                        CornerRadius="6" Background="#000000">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#632810" BlurRadius="16"
                                                          ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Image x:Name="PlayPreviewImage"
                                           Stretch="None"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="12" Background="#CC000000" CornerRadius="4"
                            Padding="8,4" IsHitTestVisible="False">
                        <TextBlock Text="▶ SPRITE" Foreground="#FF9900"
                                   FontFamily="Consolas" FontSize="11"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ PASEK STATUSU ══════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#111" BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0" Padding="10,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusFrameLabel" Text="Klatka 1/1"
                           Foreground="#FF9900" FontFamily="Consolas" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock x:Name="StatusInfoLabel" Text=""
                           Foreground="#555" FontFamily="Consolas" FontSize="10"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
