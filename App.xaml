<Application x:Class="OledPaintPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ══ HdrBtn — globalny styl przycisku nagłówka ════════════════════ -->
        <Style x:Key="HdrBtn" TargetType="{x:Type Button}">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="#242424"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#D8D8D8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#333333"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ PanelBtn — wariant HdrBtn dla bocznego panelu ════════════════ -->
        <Style x:Key="PanelBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource HdrBtn}">
            <Setter Property="Height"  Value="30"/>
            <Setter Property="Padding" Value="18,0"/>
        </Style>

        <!-- ══ Ciemny ContextMenu ═══════════════════════════════════════════ -->
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#1A1A1A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="2">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="14"
                                                  ShadowDepth="3" Opacity="0.65"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Ciemny MenuItem ═══════════════════════════════════════════════ -->
        <Style TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground"   Value="#C0C0C0"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Padding"      Value="24,6,20,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2240"/>
                                <Setter Property="Foreground" Value="#99BBFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Ciemny Separator w menu ══════════════════════════════════════ -->
        <Style TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Height"  Value="1"/>
            <Setter Property="Margin"  Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Fill="#2A2A2A" Height="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
